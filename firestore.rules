rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - email: string (required) - User email
    //   - username: string (required) - In-game name
    //   - playerId: string (required) - Unique 10-digit player ID
    //   - level: number (required) - Current level
    //   - xp: number (required) - Current experience points
    //   - hp: number (required) - Current health points
    //   - clanName: string (required) - Current clan name
    //   - resources: map (required) - Resources (copper, silver, gold, diamonds, iron, gems)
    //   - backpackItems: list (required) - Array of item objects
    //   - equippedItems: map (required) - Map of slots to items
    //   - bankAccount: map (required) - Bank account data
    //   - currentCity: string (required) - Current city name
    //   - injuries: number (required) - Number of injuries
    //   - blessing: map (required) - Blessing status
    //   - mailMessages: list (required) - Array of mail objects
    //   - isAccountHidden: bool (required) - Visibility setting
    //   - isAdmin: bool (required) - Admin status
    //   - updatedAt: number (required) - Last update timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true) ||
          ("email" in request.auth.token && request.auth.token.email == "alexeivasilev27081994@gmail.com" && "email_verified" in request.auth.token && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'username', 'playerId', 'level', 'xp', 'hp', 'clanName', 'resources', 'backpackItems', 'equippedItems', 'bankAccount', 'currentCity', 'injuries', 'blessing', 'mailMessages', 'isAccountHidden', 'isAdmin', 'isTutorial', 'updatedAt']) &&
             data.uid is string &&
             data.email is string &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.playerId is string && data.playerId.size() >= 5 && data.playerId.size() <= 10 &&
             data.level is number && data.level >= 1 &&
             data.xp is number && data.xp >= 0 &&
             data.hp is number && data.hp >= 0 &&
             data.clanName is string &&
             data.resources is map &&
             data.backpackItems is list &&
             data.equippedItems is map &&
             data.bankAccount is map &&
             data.currentCity is string &&
             data.injuries is number &&
             data.blessing is map &&
             data.mailMessages is list &&
             data.isAccountHidden is bool &&
             data.isAdmin is bool &&
             data.isTutorial is bool &&
             (!('graphicsSettings' in data) || data.graphicsSettings is map) &&
             data.updatedAt is number;
    }

    match /users/{userId} {
      // Allow users to read their own profile, or anyone if not hidden (or admin)
      // Use get() for non-existent documents to avoid errors in list queries
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin() || (resource != null && resource.data.isAccountHidden == false));
      
      // Allow creation if authenticated and data is valid
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.isAdmin == false || isAdmin());
      
      // Allow updates if owner and data is valid
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.isAdmin == resource.data.isAdmin || isAdmin());
      
      // Allow admins to delete
      allow delete: if isAdmin();
    }

    match /clans/{clanId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
